# ── Browserbase ──────────────────────────────────────────────────────────────
# Cloud browsers that web-autopilot drives. Create a project + key:
#   https://www.browserbase.com  →  Settings → API Keys
BROWSERBASE_API_KEY=bb_live_xxxxxxxxxxxxxxxxxxxxxxxx
BROWSERBASE_PROJECT_ID=00000000-0000-0000-0000-000000000000

# ── Planning model (Stagehand) ───────────────────────────────────────────────
# The LLM that turns "click the login button" into browser actions.
# Defaults to Google Gemini. Get a key: https://aistudio.google.com/apikey
MODEL_API_KEY=your-model-api-key
# Optional override (any Stagehand-supported model id):
# MODEL_NAME=google/gemini-2.5-flash

# ── Example-only (used by examples/cookie-auth.ts) ────────────────────────────
# Bring-your-own-session: a cookie YOU exported from YOUR OWN logged-in browser,
# for a service you own or are authorized to automate. Keep real values out of git.
# APP_URL=https://app.example.com
# APP_SESSION_COOKIE=
